# Copy this file to .env for local reference (Spring Boot reads these as
# real environment variables, not from a .env file, unless you use a tool
# like direnv or export them in your shell).

# --- Required in production ---
SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://HOST:PORT/DBNAME
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password
ADMIN_TOKEN=replace-with-a-long-random-string

# Comma-separated list of origins allowed to call this API
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# --- Optional: contact form email notifications ---
MAIL_ENABLED=false
NOTIFY_EMAIL=gnanasekharchandra@gmail.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_app_password

# Render/Railway set PORT automatically — no action needed
PORT=8080
